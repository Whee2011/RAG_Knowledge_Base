# RAG 知识库系统 - 环境配置模板
# ==================== 向量数据库 ====================
CHROMA_DB_PATH={INSTALL_DIR}\chroma_db
COLLECTION_NAME=knowledge_base

# ==================== LLM 大模型配置 ====================
# LLM Server URL (for chat/completions)
LLM_BASE_URL=http://127.0.0.1:1234
# LLM Model Name
LLM_MODEL=qwen/qwen3.5-9b
# LLM API Key (required for authentication)
# Leave empty if no authentication needed
API_KEY=

# ==================== Embedding 大模型配置 ====================
# Embedding Server URL (for text embeddings)
# Usually same as LLM_BASE_URL, but can be different if using separate server
EMBEDDING_BASE_URL=http://127.0.0.1:1234
# Embedding Model Name
EMBEDDING_MODEL=text-embedding-qwen3-embedding-4b
# Embedding API Key (独立配置，便于连接不同服务器)
# Leave empty to use LLM API Key (API_KEY)
EMBEDDING_API_KEY=

# ==================== 文本处理配置 ====================
CHUNK_SIZE=800
CHUNK_OVERLAP=100

# ==================== 文档目录 ====================
DOCUMENTS_DIR={INSTALL_DIR}\documents
EXCEL_DIR={INSTALL_DIR}\documents\excel
PDF_DIR={INSTALL_DIR}\documents\pdf
TXT_DIR={INSTALL_DIR}\documents\txt
DOCX_DIR={INSTALL_DIR}\documents\docx

# ==================== 导出配置 ====================
EXPORT_DIR={INSTALL_DIR}\exports